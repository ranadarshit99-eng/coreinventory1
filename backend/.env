DATABASE_URL=sqlite:///./coreinventory.db
SECRET_KEY=supersecretkey-change-in-production-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# SMTP settings for real OTP emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=CoreInventory <your-email@gmail.com>

# For SMS OTP (Twilio - optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

FRONTEND_URL=http://localhost:5173
OTP_EXPIRE_MINUTES=10
